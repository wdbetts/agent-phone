# Agent Phone Configuration
# Copy to .env and fill in values

# Mode: "mock" or "live"
MODE=mock

# Twilio credentials (only needed for live mode)
TWILIO_SID=
TWILIO_AUTH_TOKEN=
# Leave blank to auto-provision a US number during setup (via setup-wizard.js)
TWILIO_PHONE_NUMBER=

# Developer's phone number (only needed for live mode)
DEVELOPER_PHONE_NUMBER=

# Claude provider: "anthropic" (direct API) or "bedrock" (Amazon Bedrock)
CLAUDE_PROVIDER=anthropic

# Anthropic API key (when CLAUDE_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# AWS Bedrock config (when CLAUDE_PROVIDER=bedrock)
# Uses standard AWS credential chain (env vars, ~/.aws/credentials, IAM role)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# BEDROCK_MODEL=us.anthropic.claude-sonnet-4-20250514-v1:0

# Server config
PORT=3000
HOST=0.0.0.0

# Mock Twilio port (dev mode only)
MOCK_TWILIO_PORT=3001
MOCK_PHONE_PORT=3002

# Tunnel URL (set automatically by cloudflared, or manually for ngrok)
TUNNEL_URL=
